{
  "$version": 2,
  "general": {
    "gitCoAuthor": "Qwen3-Coder <noreply@qwen.ai>",
    "autoUpdate": true
  },
  "output": {
    "format": "text"
  },
  "model": {
    "name": "coder-model"
  },
  "tools": {
    "approvalMode": "yolo",
    "sandbox": true,
    "shell": "/bin/bash",
    "skills": {
      "enabled": true,
      "skillPath": "~/.qwen/skills"
    }
  },
  "context": {
    "contextFiles": ["QWEN.md"],
    "includePatterns": ["**/*.java", "**/*.py", "**/*.js", "**/*.ts", "**/*.go"],
    "excludePatterns": ["**/node_modules/**", "**/target/**", "**/.git/**", "**/build/**"]
  },
  "security": { "auth": { "selectedType": "qwen-oauth" } },
  "mcpServers": {
    "vibe_kanban": {
      "command": "npx",
      "args": ["-y", "vibe-kanban@latest", "--mcp"],
      "timeout": 15000
    }
  }
}
